# --- TLS en red corporativa (solo desarrollo local) ---
# Opción A (recomendada): cadena PEM de la CA corporativa / proxy de inspección
#   set NODE_EXTRA_CA_CERTS=C:\ruta\corp-root.pem
#   npm run dev
# Opción B: desactiva verificación TLS en Node (NO usar en producción)
#   npm run dev:insecure-tls -- --port 3000
#
# Comprobar variables antes de arrancar:
#   npm run verify:env

# Supabase project (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public site URL (callbacks, links en emails si los añades más adelante).
# Local: http://localhost:3000  |  Producción: https://host/carpeta (sin barra final inconsistente)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Subcarpeta bajo el mismo host (IIS / reverse proxy), p. ej. /zip_mundial.
# Vacío en local en raíz. En el servidor de despliegue: NEXT_PUBLIC_BASE_PATH=/zip_mundial
# (debe coincidir con next.config basePath en el momento del build).
# NEXT_PUBLIC_BASE_PATH=

# Aplicar migraciones (orden numérico):
#   supabase link --project-ref <ref>
#   supabase db push
